<UserControl x:Class="VisionHmi.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,10,0,4" />
        </Style>
        <Style x:Key="Field" TargetType="TextBox" BasedOn="{StaticResource TextBoxBase}">
            <Setter Property="Padding" Value="8,7" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="330" />
        </Grid.ColumnDefinitions>

        <!-- User list -->
        <Border Grid.Column="0" Background="{StaticResource Panel}" CornerRadius="10"
                BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="2">
            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected, Mode=TwoWay}"
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" CanUserAddRows="False" BorderThickness="0"
                      Background="Transparent" RowBackground="{StaticResource Card}"
                      AlternatingRowBackground="{StaticResource CardAlt}" Foreground="{StaticResource TextPrimary}"
                      HorizontalGridLinesBrush="{StaticResource Border}" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                    <DataGridTextColumn Header="Tên đăng nhập" Binding="{Binding Username}" Width="*" />
                    <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="*" />
                    <DataGridTextColumn Header="Quyền" Binding="{Binding Role}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Edit form -->
        <Border Grid.Column="1" Margin="16,0,0,0" Background="{StaticResource Panel}" CornerRadius="10"
                BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="18">
            <StackPanel>
                <TextBlock Text="Chi tiết người dùng" Foreground="{StaticResource TextPrimary}"
                           FontSize="15" FontWeight="SemiBold" />

                <TextBlock Text="Tên đăng nhập" Style="{StaticResource Lbl}" />
                <TextBox Style="{StaticResource Field}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Họ và tên" Style="{StaticResource Lbl}" />
                <TextBox Style="{StaticResource Field}" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Mật khẩu (để trống nếu không đổi)" Style="{StaticResource Lbl}" />
                <TextBox Style="{StaticResource Field}" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Quyền" Style="{StaticResource Lbl}" />
                <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding Role, Mode=TwoWay}"
                          Padding="8,6" FontSize="13" />

                <WrapPanel Margin="0,18,0,0">
                    <Button Content="Mới" Command="{Binding NewFormCommand}" Style="{StaticResource CmdBtn}" Margin="0,0,8,8" />
                    <Button Content="Thêm" Command="{Binding CreateCommand}" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,8" />
                    <Button Content="Cập nhật" Command="{Binding UpdateCommand}" Style="{StaticResource CmdBtn}" Margin="0,0,8,8" />
                    <Button Content="Xóa" Command="{Binding DeleteCommand}" Style="{StaticResource DangerBtn}" Margin="0,0,8,8" />
                </WrapPanel>

                <Border Background="{StaticResource Input}" CornerRadius="6" Padding="10,7" Margin="0,8,0,0">
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}"
                               FontSize="12" TextWrapping="Wrap" />
                </Border>

                <Button Content="Tải lại danh sách" Command="{Binding LoadCommand}"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Foreground="{StaticResource AccentLight}" HorizontalAlignment="Left" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

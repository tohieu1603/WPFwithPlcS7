<Window x:Class="VisionHmi.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VisionHmi.ViewModels"
        xmlns:v="clr-namespace:VisionHmi.Views"
        Title="Vision Line © To Hieu" Height="860" Width="1320"
        MinHeight="640" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgGradient}" FontFamily="Segoe UI">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:OverviewViewModel}"><v:OverviewView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:InspectionViewModel}"><v:InspectionView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AlarmsViewModel}"><v:AlarmsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:RecipeViewModel}"><v:RecipeView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}"><v:UsersView /></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="212" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="16,20,16,16">
                    <TextBlock Text="VISION LINE" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="Bold" />
                    <TextBlock Text="PackML · Track &amp; Trace" Style="{StaticResource Caption}" Margin="0,3,0,0" />
                </StackPanel>
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <RadioButton Style="{StaticResource NavBtn}" IsChecked="True" Command="{Binding NavOverviewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconOverview}" Width="17" Height="17" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                            <TextBlock Text="Overview" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavBtn}" Command="{Binding NavInspectionCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconInspection}" Width="17" Height="17" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                            <TextBlock Text="Inspection" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavBtn}" Command="{Binding NavAlarmsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconAlarms}" Width="17" Height="17" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                            <TextBlock Text="Alarms" Margin="12,0,0,0" VerticalAlignment="Center" />
                            <Border Background="{StaticResource Fault}" CornerRadius="8" MinWidth="18" Height="16" Padding="4,0" Margin="10,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding Alarms.ActiveCount, Converter={StaticResource CountToVisibility}}">
                                <TextBlock Text="{Binding Alarms.ActiveCount}" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavBtn}" Command="{Binding NavRecipeCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconRecipe}" Width="17" Height="17" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                            <TextBlock Text="Recipe" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavBtn}" Command="{Binding NavUsersCommand}"
                                 Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Users" Margin="29,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
                <Border Grid.Row="2" Padding="16" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0"
                                 Fill="{Binding Connected, Converter={StaticResource BoolToBrush}}" />
                        <TextBlock Text="{Binding LinkText}" Style="{StaticResource Caption}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="52" /><RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <Grid Margin="16,0">
                    <TextBlock Text="{Binding ActiveNav}" Style="{StaticResource H1}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border CornerRadius="9" Padding="12,5" Background="{StaticResource Input}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="11" Height="11" VerticalAlignment="Center"
                                         Fill="{Binding Overview.StateText, Converter={StaticResource StateToBrush}}" />
                                <TextBlock Text="{Binding Overview.StateText}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <StackPanel Margin="18,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUserName}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding CurrentUserRole}" Foreground="{StaticResource TextMuted}" FontSize="11" HorizontalAlignment="Right" />
                        </StackPanel>
                        <Button Content="Đăng xuất" Command="{Binding LogoutCommand}" Style="{StaticResource CmdBtn}" />
                    </StackPanel>
                </Grid>
            </Border>
            <ContentControl Grid.Row="1" Content="{Binding Current}" />
        </Grid>
    </Grid>
</Window>

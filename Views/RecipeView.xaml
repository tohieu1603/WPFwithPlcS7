<UserControl x:Class="VisionHmi.Views.RecipeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="Lbl" BasedOn="{StaticResource Caption}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxBase}">
            <Setter Property="Width" Value="130" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="RECIPE / SETPOINTS — DB12" Style="{StaticResource H1}" Margin="0,0,0,14" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,12,0" VerticalAlignment="Top">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0"><TextBlock Text="Recipe No." Style="{StaticResource Lbl}" /><TextBox Text="{Binding RecipeNumber}" /></StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1"><TextBlock Text="Cycle target (s)" Style="{StaticResource Lbl}" /><TextBox Text="{Binding CycleTarget, StringFormat=F0}" /></StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2"><TextBlock Text="Press force (N)" Style="{StaticResource Lbl}" /><TextBox Text="{Binding PressForce, StringFormat=F0}" /></StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0"><TextBlock Text="Screw torque (Nm)" Style="{StaticResource Lbl}" /><TextBox Text="{Binding ScrewTorque, StringFormat=F2}" /></StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1"><TextBlock Text="Gap nominal (mm)" Style="{StaticResource Lbl}" /><TextBox Text="{Binding GapNominal, StringFormat=F3}" /></StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2"><TextBlock Text="Gap tol +/- (mm)" Style="{StaticResource Lbl}" /><TextBox Text="{Binding GapTol, StringFormat=F3}" /></StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0"><TextBlock Text="Vision min score (%)" Style="{StaticResource Lbl}" /><TextBox Text="{Binding VisionMinScore, StringFormat=F0}" /></StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1"><TextBlock Text="Barcode min grade" Style="{StaticResource Lbl}" /><TextBox Text="{Binding BarcodeMinGrade}" /></StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="DOWNLOAD TO PLC" Command="{Binding DownloadCommand}" Style="{StaticResource PrimaryBtn}" />
                        <Button Content="RELOAD" Command="{Binding ReloadCommand}" Style="{StaticResource CmdBtn}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="ACTIVE IN PLC" Style="{StaticResource Caption}" Margin="0,0,0,10" />
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Gap nominal" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding ActiveGapNominal, StringFormat='{}{0:F3} mm'}" HorizontalAlignment="Right" Style="{StaticResource Value}" FontSize="13" />
                    </Grid>
                    <Grid>
                        <TextBlock Text="Vision min score" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding ActiveVisionMinScore, StringFormat='{}{0:F0} %'}" HorizontalAlignment="Right" Style="{StaticResource Value}" FontSize="13" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

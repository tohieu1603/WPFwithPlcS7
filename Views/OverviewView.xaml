<UserControl x:Class="VisionHmi.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:VisionHmi.Views">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- PackML control bar -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <TextBlock Text="MACHINE STATE" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding StateText}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding ModeText}" Style="{StaticResource Caption}" Margin="0,0,12,0" />
                        <TextBlock Text="{Binding LineRate, StringFormat='{}{0:F1} ppm'}" Style="{StaticResource Caption}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <WrapPanel>
                        <Button Content="RESET"  Command="{Binding ResetCommand}"  Style="{StaticResource CmdBtn}" />
                        <Button Content="START"  Command="{Binding StartCommand}"  Style="{StaticResource PrimaryBtn}" />
                        <Button Content="STOP"   Command="{Binding StopCommand}"   Style="{StaticResource CmdBtn}" />
                        <Button Content="HOLD"   Command="{Binding HoldCommand}"   Style="{StaticResource CmdBtn}" />
                        <Button Content="UNHOLD" Command="{Binding UnholdCommand}" Style="{StaticResource CmdBtn}" />
                        <Button Content="ABORT"  Command="{Binding AbortCommand}"  Style="{StaticResource DangerBtn}" />
                        <Button Content="CLEAR"  Command="{Binding ClearCommand}"  Style="{StaticResource CmdBtn}" />
                    </WrapPanel>
                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock Text="MODE:" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Button Content="PRODUCTION"  Command="{Binding ModeProductionCommand}"  Style="{StaticResource CmdBtn}" />
                        <Button Content="MAINTENANCE" Command="{Binding ModeMaintenanceCommand}" Style="{StaticResource CmdBtn}" />
                        <Button Content="MANUAL"      Command="{Binding ModeManualCommand}"      Style="{StaticResource CmdBtn}" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1" Text="LINE STATIONS (part flow →)" Style="{StaticResource Caption}" Margin="2,0,0,8" />
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Stations}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate><DataTemplate><v:StationControl /></DataTemplate></ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- KPI -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>
            <UniformGrid Grid.Column="0" Rows="1" Margin="0,0,12,0">
                <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="GOOD" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding Good}" Style="{StaticResource Value}" FontSize="22" Foreground="{StaticResource Run}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="REJECT" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding Reject}" Style="{StaticResource Value}" FontSize="22" Foreground="{StaticResource Fault}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="FIRST-PASS YIELD" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding Fpy, StringFormat='{}{0:F0}%'}" Style="{StaticResource Value}" FontSize="22" />
                        <ProgressBar Value="{Binding Fpy}" Style="{StaticResource Bar}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="THROUGHPUT" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding Throughput, StringFormat='{}{0:F0}'}" Style="{StaticResource Value}" FontSize="22" />
                        <TextBlock Text="parts/hour" Style="{StaticResource Caption}" />
                    </StackPanel>
                </Border>
            </UniformGrid>
            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="UTILITIES" Style="{StaticResource Caption}" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Reject bin" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding RejectBin}" HorizontalAlignment="Right" FontFamily="Consolas"
                                   Foreground="{Binding RejectBinFull, Converter={StaticResource BoolToBrush}, ConverterParameter=fault}" />
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Air pressure" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding AirPressure, StringFormat='{}{0:F2} bar'}" HorizontalAlignment="Right"
                                   Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" />
                    </Grid>
                    <UniformGrid Columns="2">
                        <Button Content="CLEAR COUNTERS" Command="{Binding ClearCountersCommand}" Style="{StaticResource CmdBtn}" />
                        <Button Content="EMPTY BIN" Command="{Binding EmptyRejectBinCommand}" Style="{StaticResource CmdBtn}" />
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="VisionHmi.Views.StationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardBorder}" Width="138" Margin="0,0,8,8">
        <StackPanel>
            <Grid>
                <StackPanel>
                    <TextBlock Text="{Binding Name}" Style="{StaticResource H1}" />
                    <TextBlock Text="{Binding Code}" Style="{StaticResource Caption}" />
                </StackPanel>
                <Ellipse Width="14" Height="14" VerticalAlignment="Top" HorizontalAlignment="Right"
                         Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" />
            </Grid>
            <Border Height="1" Background="{StaticResource Border}" Margin="0,8" />
            <Grid Margin="0,0,0,3">
                <TextBlock Text="STATUS" Style="{StaticResource Caption}" />
                <TextBlock Text="{Binding Status}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="12"
                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}" />
            </Grid>
            <Grid>
                <TextBlock Text="COUNT" Style="{StaticResource Caption}" />
                <TextBlock Text="{Binding Count}" HorizontalAlignment="Right" Foreground="{StaticResource TextPrimary}"
                           FontFamily="Consolas" FontSize="12" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>

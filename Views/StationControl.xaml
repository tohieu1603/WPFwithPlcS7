<UserControl x:Class="VisionHmi.Views.StationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <!-- equipment housing -->
        <Border Style="{StaticResource EquipmentTile}">
            <StackPanel>
                <Grid>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Code}" Foreground="{StaticResource TextSecondary}" FontSize="10" />
                    </StackPanel>
                    <Ellipse Width="12" Height="12" VerticalAlignment="Top" HorizontalAlignment="Right"
                             Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" Stroke="#40000000" StrokeThickness="1" />
                </Grid>

                <Grid Width="62" Height="62" Margin="0,8" HorizontalAlignment="Center">
                    <Ellipse x:Name="Pulse" Width="54" Height="54" StrokeThickness="2" Opacity="0"
                             Stroke="{Binding Status, Converter={StaticResource StatusToBrush}}" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform><ScaleTransform /></Ellipse.RenderTransform>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Busy}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="PulseSb">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.5" To="0" Duration="0:0:1.1" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1" To="1.3" Duration="0:0:1.1" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="1.3" Duration="0:0:1.1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="PulseSb" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Ellipse Width="54" Height="54" Fill="{StaticResource RingTrack}"
                             Stroke="{Binding Status, Converter={StaticResource StatusToBrush}}" StrokeThickness="2" />
                    <Path Data="{Binding Code, Converter={StaticResource StationIcon}}" Fill="{StaticResource TextPrimary}"
                          Stretch="Uniform" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <!-- the physical unit sitting at this station -->
                <Border Height="20" CornerRadius="4" Background="{StaticResource PartToken}" Margin="0,0,0,6" Padding="9,0"
                        HorizontalAlignment="Center" Visibility="{Binding Present, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="UNIT ON DECK" Foreground="#3A2A06" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" />
                </Border>

                <Grid>
                    <StackPanel HorizontalAlignment="Left">
                        <TextBlock Text="COUNT" Foreground="{StaticResource TextSecondary}" FontSize="9" />
                        <TextBlock Text="{Binding Count}" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="14" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right">
                        <TextBlock Text="CYCLE" Foreground="{StaticResource TextSecondary}" FontSize="9" HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding CycleTime, StringFormat='{}{0:F1}s'}" Foreground="{StaticResource TextSecondary}"
                                   FontFamily="Consolas" FontSize="12" HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>

                <!-- progress: how far the line has been carried (PASSED/ACTIVE/PENDING) -->
                <Border Height="4" CornerRadius="2" Margin="0,8,0,0" Background="{Binding Phase, Converter={StaticResource PhaseToBrush}}" />
            </StackPanel>
        </Border>

        <!-- conveyor belt segment to the next station -->
        <Grid Width="42" Height="62" VerticalAlignment="Center">
            <Border Height="16" VerticalAlignment="Center" CornerRadius="3"
                    Background="{StaticResource ConveyorBody}" BorderBrush="{StaticResource ConveyorEdge}" BorderThickness="1" />
            <Line x:Name="Belt" X1="3" Y1="31" X2="39" Y2="31" Stroke="{StaticResource BeltDash}" StrokeThickness="3" StrokeDashArray="2 2.5">
                <Line.Style>
                    <Style TargetType="Line">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LineRunning}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="BeltSb">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="StrokeDashOffset" From="4.5" To="0" Duration="0:0:0.55" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="BeltSb" />
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Line.Style>
            </Line>
            <Path Data="M0,0 L7,5 L0,10 Z" Fill="{StaticResource BeltDash}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,3,0" />
        </Grid>
    </StackPanel>
</UserControl>

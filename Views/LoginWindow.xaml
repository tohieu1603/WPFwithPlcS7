<Window x:Class="VisionHmi.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vision Line — Đăng nhập" Height="600" Width="440"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource BgGradient}" FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="B2V" />
        <Style x:Key="Field" TargetType="TextBox" BasedOn="{StaticResource TextBoxBase}">
            <Setter Property="Margin" Value="0,4,0,12" />
            <Setter Property="Padding" Value="8,7" />
        </Style>
        <Style x:Key="Pw" TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource Input}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,7" />
            <Setter Property="Margin" Value="0,4,0,12" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid>
        <Border Width="360" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="{StaticResource Panel}" CornerRadius="14" Padding="28"
                BorderBrush="{StaticResource Border}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="VISION LINE" Foreground="{StaticResource TextPrimary}"
                           FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Title}" Foreground="{StaticResource AccentLight}"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,4,0,22" />

                <TextBlock Text="Tên đăng nhập" Style="{StaticResource Lbl}" />
                <TextBox Style="{StaticResource Field}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Visibility="{Binding IsRegister, Converter={StaticResource B2V}}">
                    <TextBlock Text="Họ và tên" Style="{StaticResource Lbl}" />
                    <TextBox Style="{StaticResource Field}"
                             Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <TextBlock Text="Mật khẩu" Style="{StaticResource Lbl}" />
                <PasswordBox x:Name="PwBox" Style="{StaticResource Pw}" PasswordChanged="PwBox_Changed" />

                <StackPanel Visibility="{Binding IsRegister, Converter={StaticResource B2V}}">
                    <TextBlock Text="Nhập lại mật khẩu" Style="{StaticResource Lbl}" />
                    <PasswordBox x:Name="ConfirmBox" Style="{StaticResource Pw}" PasswordChanged="ConfirmBox_Changed" />
                </StackPanel>

                <TextBlock Text="{Binding Error}" Foreground="{StaticResource Fault}" FontSize="12"
                           TextWrapping="Wrap" Margin="0,2,0,10" MinHeight="16" />

                <Button Content="{Binding SubmitText}" Command="{Binding SubmitCommand}"
                        Style="{StaticResource PrimaryBtn}" Height="40" IsEnabled="{Binding NotBusy}" />

                <Button Content="{Binding ToggleText}" Command="{Binding ToggleModeCommand}"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Foreground="{StaticResource TextSecondary}" Margin="0,14,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

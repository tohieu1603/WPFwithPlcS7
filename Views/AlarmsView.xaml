<UserControl x:Class="VisionHmi.Views.AlarmsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- header: title, priority summary, acknowledge -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ALARM MANAGEMENT" Style="{StaticResource H1}" FontSize="16" VerticalAlignment="Center" />
                    <Border Style="{StaticResource Pill}" Background="{StaticResource Fault}" Margin="16,0,0,0">
                        <TextBlock Text="{Binding CriticalCount, StringFormat='CRIT {0}'}" Foreground="White" FontSize="11" FontWeight="Bold" />
                    </Border>
                    <Border Style="{StaticResource Pill}" Background="{StaticResource Warn}" Margin="8,0,0,0">
                        <TextBlock Text="{Binding HighCount, StringFormat='HIGH {0}'}" Foreground="White" FontSize="11" FontWeight="Bold" />
                    </Border>
                    <Border Style="{StaticResource Pill}" Background="{StaticResource Accent}" Margin="8,0,0,0">
                        <TextBlock Text="{Binding MediumCount, StringFormat='MED {0}'}" Foreground="White" FontSize="11" FontWeight="Bold" />
                    </Border>
                    <Border Style="{StaticResource Pill}" Background="{StaticResource Idle}" Margin="8,0,0,0">
                        <TextBlock Text="{Binding ActiveCount, StringFormat='TOTAL {0}'}" Foreground="White" FontSize="11" FontWeight="Bold" />
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LastAck, StringFormat='last ack {0}'}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Content="ACKNOWLEDGE ALL" Command="{Binding AcknowledgeCommand}" Style="{StaticResource PrimaryBtn}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- active alarms | event log -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <!-- active -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,12,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource CardAlt}" CornerRadius="8,8,0,0" Padding="14,10">
                        <TextBlock Text="ACTIVE ALARMS" Style="{StaticResource Caption}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,4">
                        <ItemsControl ItemsSource="{Binding Active}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="0,9">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5" /><ColumnDefinition Width="86" />
                                                <ColumnDefinition Width="64" /><ColumnDefinition Width="180" /><ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="2" Background="{Binding Priority, Converter={StaticResource PriorityToBrush}}" Margin="0,0,10,0" />
                                            <Border Grid.Column="1" Style="{StaticResource Pill}" Padding="7,2" VerticalAlignment="Center"
                                                    Background="{Binding Priority, Converter={StaticResource PriorityToBrush}}">
                                                <TextBlock Text="{Binding Priority}" FontSize="10" FontWeight="Bold" Foreground="White" />
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Station}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                                            <TextBlock Grid.Column="3" Text="{Binding Name}" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" />
                                            <TextBlock Grid.Column="4" Text="{Binding Description}" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- event log -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource CardAlt}" CornerRadius="8,8,0,0" Padding="14,10">
                        <TextBlock Text="EVENT LOG (came / cleared)" Style="{StaticResource Caption}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,4">
                        <ItemsControl ItemsSource="{Binding History}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="0,7">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="62" /><ColumnDefinition Width="70" /><ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Time}" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" />
                                            <Border Grid.Column="1" Padding="6,1" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource Pill}">
                                                        <Setter Property="Background" Value="{StaticResource Run}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Transition}" Value="ALARM">
                                                                <Setter Property="Background" Value="{StaticResource Fault}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Transition}" FontSize="9" FontWeight="Bold" Foreground="White" />
                                            </Border>
                                            <StackPanel Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextPrimary}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

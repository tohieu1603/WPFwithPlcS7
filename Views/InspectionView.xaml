<UserControl x:Class="VisionHmi.Views.InspectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Current unit -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <Grid>
                <StackPanel>
                    <TextBlock Text="UNIT IN PROCESS" Style="{StaticResource Caption}" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding CurSerial}" FontFamily="Consolas" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Text="{Binding CurProduct}" Style="{StaticResource Caption}" VerticalAlignment="Bottom" Margin="14,0,0,4" />
                    </StackPanel>
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Center" CornerRadius="3" Padding="16,8"
                        Background="{Binding DispositionText, Converter={StaticResource DispositionToBrush}}">
                    <TextBlock Text="{Binding DispositionText}" FontWeight="Bold" FontSize="16" Foreground="White" />
                </Border>
            </Grid>
        </Border>

        <!-- 3 device cards -->
        <UniformGrid Grid.Row="1" Columns="3">
            <!-- BARCODE -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="BARCODE · ST20" Style="{StaticResource Caption}" Margin="0,0,0,10" />
                    <Grid Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{Binding BcrReadOk, Converter={StaticResource BoolToBrush}}" />
                            <TextBlock Text="{Binding BcrReadOk, Converter={StaticResource BoolToText}, ConverterParameter='READ OK|NO-READ'}"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="CODE" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding BcrData}" FontFamily="Consolas" FontSize="18" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10" />
                    <Grid>
                        <TextBlock Text="Print grade" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding BcrGrade}" HorizontalAlignment="Right" Style="{StaticResource Value}" FontSize="14" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- VISION -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="VISION · ST40" Style="{StaticResource Caption}" Margin="0,0,0,10" />
                    <Border CornerRadius="3" Padding="0,8" Margin="0,0,0,10" HorizontalAlignment="Stretch"
                            Background="{Binding VisPass, Converter={StaticResource BoolToBrush}}">
                        <TextBlock Text="{Binding VisPass, Converter={StaticResource BoolToText}, ConverterParameter='PASS|FAIL'}"
                                   FontWeight="Bold" FontSize="20" Foreground="White" HorizontalAlignment="Center" />
                    </Border>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Match score" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding VisScore, StringFormat='{}{0:F1} %'}" HorizontalAlignment="Right" Style="{StaticResource Value}" FontSize="14" />
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Gap (VF03)" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding VisMeasure1, StringFormat='{}{0:F3} mm'}" HorizontalAlignment="Right" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" />
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Bore (VF04)" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding VisMeasure2, StringFormat='{}{0:F3} mm'}" HorizontalAlignment="Right" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" />
                    </Grid>
                    <Grid>
                        <TextBlock Text="Result code" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding VisResultCode}" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- MARK + VERIFY -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="MARK · ST50  /  VERIFY · ST60" Style="{StaticResource Caption}" Margin="0,0,0,10" />
                    <TextBlock Text="MARKED SERIAL" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding MarkedSerial}" FontFamily="Consolas" FontSize="18" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{Binding VerifyMatch, Converter={StaticResource BoolToBrush}}" />
                            <TextBlock Text="{Binding VerifyMatch, Converter={StaticResource BoolToText}, ConverterParameter='VERIFY OK|MISMATCH'}"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <TextBlock Text="Print grade" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding VerifyGrade}" HorizontalAlignment="Right" Style="{StaticResource Value}" FontSize="14" />
                    </Grid>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Reject breakdown -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="REJECTS BY REASON:" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,16,0" />
                <TextBlock Text="{Binding RejVision, StringFormat='Vision {0}'}" Foreground="{StaticResource TextPrimary}" Margin="0,0,18,0" />
                <TextBlock Text="{Binding RejBarcode, StringFormat='Barcode {0}'}" Foreground="{StaticResource TextPrimary}" Margin="0,0,18,0" />
                <TextBlock Text="{Binding RejVerify, StringFormat='Verify {0}'}" Foreground="{StaticResource TextPrimary}" Margin="0,0,18,0" />
                <TextBlock Text="{Binding RejAssembly, StringFormat='Assembly {0}'}" Foreground="{StaticResource TextPrimary}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

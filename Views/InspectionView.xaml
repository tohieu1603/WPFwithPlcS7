<UserControl x:Class="VisionHmi.Views.InspectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:VisionHmi.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- current unit + summary -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="UNIT IN PROCESS" Style="{StaticResource Caption}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding CurSerial}" FontFamily="Consolas" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="{Binding CurProduct}" Style="{StaticResource Caption}" VerticalAlignment="Bottom" Margin="14,0,0,5" />
                            <Border Style="{StaticResource Pill}" Padding="14,5" Margin="16,0,0,2" VerticalAlignment="Center"
                                    Background="{Binding DispositionText, Converter={StaticResource DispositionToBrush}}">
                                <TextBlock Text="{Binding DispositionText}" FontWeight="Bold" FontSize="14" Foreground="White" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="18,0"><TextBlock Text="TOTAL" Style="{StaticResource Caption}" /><TextBlock Text="{Binding Total}" Style="{StaticResource Value}" FontSize="22" /></StackPanel>
                        <StackPanel Margin="18,0"><TextBlock Text="GOOD" Style="{StaticResource Caption}" /><TextBlock Text="{Binding Good}" Style="{StaticResource Value}" FontSize="22" Foreground="{StaticResource Run}" /></StackPanel>
                        <StackPanel Margin="18,0"><TextBlock Text="REJECT" Style="{StaticResource Caption}" /><TextBlock Text="{Binding Reject}" Style="{StaticResource Value}" FontSize="22" Foreground="{StaticResource Fault}" /></StackPanel>
                        <StackPanel Margin="18,0,0,0"><TextBlock Text="FPY" Style="{StaticResource Caption}" /><TextBlock Text="{Binding Fpy, StringFormat='{}{0:F0}%'}" Style="{StaticResource Value}" FontSize="22" Foreground="{StaticResource Warn}" /></StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- device cards -->
            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,12">
                <!-- BARCODE -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <Path Data="{StaticResource IconScan}" Fill="{StaticResource AccentLight}" Width="16" Height="16" Stretch="Uniform" DockPanel.Dock="Left" />
                            <TextBlock Text="BARCODE IDENTIFY · ST20" Style="{StaticResource Caption}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <Border Background="White" CornerRadius="3" Padding="8,6">
                            <ctl:BarcodeControl Text="{Binding BcrData}" BarBrush="Black" Height="48" />
                        </Border>
                        <TextBlock Text="{Binding BcrData}" FontFamily="Consolas" FontSize="16" Foreground="{StaticResource TextPrimary}" Margin="0,8,0,10" TextTrimming="CharacterEllipsis" />
                        <Grid Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Margin="0,0,8,0" VerticalAlignment="Center" Fill="{Binding BcrReadOk, Converter={StaticResource BoolToBrush}}" />
                                <TextBlock Text="{Binding BcrReadOk, Converter={StaticResource BoolToText}, ConverterParameter='READ OK|NO-READ'}"
                                           FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Print grade" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding BcrGrade}" HorizontalAlignment="Right" Style="{StaticResource Value}" FontSize="14" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- VISION -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <Path Data="{StaticResource IconVision}" Fill="{StaticResource AccentLight}" Width="16" Height="16" Stretch="Uniform" DockPanel.Dock="Left" />
                            <TextBlock Text="VISION INSPECT · ST40" Style="{StaticResource Caption}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <Border CornerRadius="3" Padding="0,9" Margin="0,0,0,12" Background="{Binding VisPass, Converter={StaticResource BoolToBrush}}">
                            <TextBlock Text="{Binding VisPass, Converter={StaticResource BoolToText}, ConverterParameter='PASS|FAIL'}"
                                       FontWeight="Bold" FontSize="22" Foreground="White" HorizontalAlignment="Center" />
                        </Border>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="Match score" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding VisScore, StringFormat='{}{0:F1} %'}" HorizontalAlignment="Right" Style="{StaticResource Value}" FontSize="14" />
                        </Grid>
                        <ProgressBar Value="{Binding VisScore}" Style="{StaticResource Bar}" Margin="0,0,0,10" />
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Gap (VF03)" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding VisMeasure1, StringFormat='{}{0:F3} mm'}" HorizontalAlignment="Right" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" />
                        </Grid>
                        <Grid>
                            <TextBlock Text="Bore (VF04)" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding VisMeasure2, StringFormat='{}{0:F3} mm'}" HorizontalAlignment="Right" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- MARK + VERIFY -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <Path Data="{StaticResource IconChip}" Fill="{StaticResource AccentLight}" Width="16" Height="16" Stretch="Uniform" DockPanel.Dock="Left" />
                            <TextBlock Text="MARK · ST50  /  VERIFY · ST60" Style="{StaticResource Caption}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="White" CornerRadius="3" Padding="6">
                                <ctl:MatrixCodeControl Text="{Binding MarkedSerial}" ModuleBrush="Black" Width="78" Height="78" />
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="MARKED SERIAL" Style="{StaticResource Caption}" />
                                <TextBlock Text="{Binding MarkedSerial}" FontFamily="Consolas" FontSize="15" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Ellipse Width="12" Height="12" Margin="0,0,8,0" VerticalAlignment="Center" Fill="{Binding VerifyMatch, Converter={StaticResource BoolToBrush}}" />
                                    <TextBlock Text="{Binding VerifyMatch, Converter={StaticResource BoolToText}, ConverterParameter='VERIFY OK|MISMATCH'}"
                                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                                </StackPanel>
                                <Grid Margin="0,8,0,0" Width="120">
                                    <TextBlock Text="Print grade" Style="{StaticResource Caption}" />
                                    <TextBlock Text="{Binding VerifyGrade}" HorizontalAlignment="Right" Style="{StaticResource Value}" FontSize="14" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- history + reject pareto -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="RECENT UNITS" Style="{StaticResource Caption}" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" />
                                <ColumnDefinition Width="70" /><ColumnDefinition Width="50" /><ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TIME" Style="{StaticResource Caption}" FontSize="10" />
                            <TextBlock Grid.Column="1" Text="SERIAL" Style="{StaticResource Caption}" FontSize="10" />
                            <TextBlock Grid.Column="2" Text="PRODUCT" Style="{StaticResource Caption}" FontSize="10" />
                            <TextBlock Grid.Column="3" Text="SCORE" Style="{StaticResource Caption}" FontSize="10" />
                            <TextBlock Grid.Column="4" Text="GR" Style="{StaticResource Caption}" FontSize="10" />
                            <TextBlock Grid.Column="5" Text="RESULT" Style="{StaticResource Caption}" FontSize="10" />
                        </Grid>
                        <Border Height="1" Background="{StaticResource Border}" Margin="0,0,0,4" />
                        <ItemsControl ItemsSource="{Binding Recent}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="70" /><ColumnDefinition Width="50" /><ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Time}" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas" FontSize="12" />
                                        <TextBlock Grid.Column="1" Text="{Binding Serial}" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" />
                                        <TextBlock Grid.Column="2" Text="{Binding Product}" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                                        <TextBlock Grid.Column="3" Text="{Binding Score, StringFormat='{}{0:F1}'}" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" />
                                        <TextBlock Grid.Column="4" Text="{Binding Grade}" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas" FontSize="12" />
                                        <Border Grid.Column="5" Style="{StaticResource Pill}" Padding="8,1" HorizontalAlignment="Left"
                                                Background="{Binding Disposition, Converter={StaticResource DispositionToBrush}}">
                                            <TextBlock Text="{Binding Disposition}" Foreground="White" FontSize="10" FontWeight="Bold" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="REJECTS BY REASON" Style="{StaticResource Caption}" Margin="0,0,0,12" />
                        <TextBlock Text="Vision" Style="{StaticResource Caption}" />
                        <Grid Margin="0,2,0,10">
                            <ProgressBar Value="{Binding RejVision}" Maximum="{Binding Reject}" Style="{StaticResource Bar}" Foreground="{StaticResource Fault}" />
                            <TextBlock Text="{Binding RejVision}" HorizontalAlignment="Right" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="11" Margin="0,-3,0,0" />
                        </Grid>
                        <TextBlock Text="Barcode" Style="{StaticResource Caption}" />
                        <Grid Margin="0,2,0,10">
                            <ProgressBar Value="{Binding RejBarcode}" Maximum="{Binding Reject}" Style="{StaticResource Bar}" Foreground="{StaticResource Warn}" />
                            <TextBlock Text="{Binding RejBarcode}" HorizontalAlignment="Right" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="11" Margin="0,-3,0,0" />
                        </Grid>
                        <TextBlock Text="Verify" Style="{StaticResource Caption}" />
                        <Grid Margin="0,2,0,10">
                            <ProgressBar Value="{Binding RejVerify}" Maximum="{Binding Reject}" Style="{StaticResource Bar}" Foreground="{StaticResource AccentLight}" />
                            <TextBlock Text="{Binding RejVerify}" HorizontalAlignment="Right" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="11" Margin="0,-3,0,0" />
                        </Grid>
                        <TextBlock Text="Assembly" Style="{StaticResource Caption}" />
                        <Grid Margin="0,2,0,0">
                            <ProgressBar Value="{Binding RejAssembly}" Maximum="{Binding Reject}" Style="{StaticResource Bar}" Foreground="{StaticResource Idle}" />
                            <TextBlock Text="{Binding RejAssembly}" HorizontalAlignment="Right" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="11" Margin="0,-3,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
